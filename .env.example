# Supabase
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=COLE_A_SERVICE_ROLE_KEY_AQUI

# Admin ZapFatri
ADMIN_PASSWORD=troque-essa-senha
APP_SECRET=troque-essa-frase-secreta-grande
IP_HASH_SALT=troque-esse-salt

# Ambiente
NODE_ENV=development
PORT=3000

# Domínios usados para mostrar os links no painel
PUBLIC_GO_BASE_URL=http://localhost:3000


# Produção recomendada
# No Render/admin, use:
# PUBLIC_GO_BASE_URL=https://go.zapfatri.com
#
# No Cloudflare Worker, crie estes secrets/vars:
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
# IP_HASH_SALT
# ALLOW_NUMERIC_PHONE_WITHOUT_LOOKUP=true
